# ============================================
# MCP (Model Context Protocol) Configuration
# ============================================
# 
# Copiez ce fichier en .env et remplissez les valeurs
# ou ajoutez ces variables dans votre ~/.zshrc
#

# Supabase MCP
# Token d'accès : https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_votre_token_ici
# Référence du projet : trouvez-la dans l'URL Supabase (https://[REF].supabase.co)
SUPABASE_PROJECT_REF=votre_project_ref

# 21st.dev Magic MCP
# Clé API : https://21st.dev/settings/api-keys
MAGIC_21ST_API_KEY=votre_cle_ici

# Context7 MCP
# Clé API : https://context7.com/settings/api-keys
CONTEXT7_API_KEY=votre_cle_ici

# Vercel (utilisé via API REST, pas de MCP)
# Token : https://vercel.com/account/tokens
VERCEL_TOKEN=vcp_YOUR_VERCEL_TOKEN

# Render (utilisé via API REST, pas de MCP)
# Clé API : https://dashboard.render.com/settings/api-keys
RENDER_API_KEY=votre_cle_ici
